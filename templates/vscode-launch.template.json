{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "StarterApplication",
      "request": "launch",
      "mainClass": "com.brunotot.starter.StarterApplication",
      "vmArgs": "-Dspring.profiles.active=dev",
      "env": {
        "SPRING_DATASOURCE_URL": "${LOCAL_SPRING_DATASOURCE_URL}",
        "SPRING_DATASOURCE_USERNAME": "${LOCAL_SPRING_DATASOURCE_USERNAME}",
        "SPRING_DATASOURCE_PASSWORD": "${LOCAL_SPRING_DATASOURCE_PASSWORD}"
      }
    }
  ]
}
